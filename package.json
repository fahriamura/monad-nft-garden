{
  "name": "monad-nft-garden",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3010 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 3010 --strictPort",
    "compile": "hardhat compile",
    "deploy:monad": "hardhat run scripts/deploy.ts --network monadTestnet",
    "verify:monad": "hardhat verify --network monadTestnet"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "ethers": "^6.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.2.3",
    "hardhat": "^2.26.3",
    "typescript": "~5.8.2"
  }
}
